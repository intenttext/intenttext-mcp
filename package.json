{
  "name": "@intenttext/mcp-server",
  "version": "1.3.3",
  "mcpName": "io.github.intenttext/intenttext-mcp",
  "description": "MCP server for IntentText — parse, validate, query, and render .it documents from any AI agent",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "bin": {
    "intenttext-mcp": "dist/index.js",
    "intenttext-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "start:http": "node dist/http.js"
  },
  "keywords": [
    "intenttext",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "parser"
  ],
  "author": "IntentText Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/intenttext/intenttext-mcp.git"
  },
  "homepage": "https://github.com/intenttext/intenttext-mcp#readme",
  "bugs": {
    "url": "https://github.com/intenttext/intenttext-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@intenttext/core": "^2.13.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
